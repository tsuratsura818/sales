# SerpAPI（Google検索）
SERPAPI_KEY=your_serpapi_key_here

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gemini API（メモ録音文字起こし用・無料枠は学習利用されるため機密会議には使わない）
# 取得: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google PageSpeed Insights API（任意）
PAGESPEED_API_KEY=

# DB
DATABASE_URL=sqlite:///./sales.db

# 分析設定
MAX_CONCURRENT_ANALYSIS=5
ANALYSIS_TIMEOUT_SEC=15
CLAUDE_MODEL=claude-opus-4-6

# Outlook送信元アドレス（表示用）
OUTLOOK_FROM_ADDRESS=your@company.com

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_USER_ID=

# クラウドソーシング認証
CROWDWORKS_EMAIL=
CROWDWORKS_PASSWORD=
LANCERS_EMAIL=
LANCERS_PASSWORD=

# 案件モニター設定
JOB_MONITOR_INTERVAL_MINUTES=30
JOB_MATCH_THRESHOLD=70
USER_PROFILE_TEXT=

# Notion連携（案件管理）
NOTION_API_KEY=
NOTION_PROJECT_DB_ID=
NOTION_TASK_DB_ID=
